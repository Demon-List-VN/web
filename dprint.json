{
    "$schema": "https://dprint.dev/schemas/v0.json",
    "json": {
        "lineWidth": 100,
        "indentWidth": 4,
        "useTabs": false,
        "trailingCommas": "never"
    },
    "markdown": {
        "lineWidth": 100
    },
    "includes": ["**/*.{json,jsonc,md,css,scss}"],
    "excludes": [
        "node_modules",
        "build",
        ".svelte-kit",
        ".wrangler",
        "coverage",
        "eslint-output.json",
        "package",
        "test-results",
        "package-lock.json",
        "LICENSE.md"
    ],
    "plugins": [
        "https://plugins.dprint.dev/json-0.20.0.wasm",
        "https://plugins.dprint.dev/markdown-0.18.0.wasm",
        "https://plugins.dprint.dev/g-plane/malva-v0.15.0.wasm"
    ]
}
